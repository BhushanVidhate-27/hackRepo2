{
  "name": "frontend-vanilla",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  
  "scripts": {
    "dev": "concurrently \"npm:backend:dev\" \"npm:frontend:dev\"",
    "prebuild": "node scripts/export-insulation-catalog.mjs",
    "build": "vite build",
    "preview": "vite preview",

    "backend": "node backend/server.js",
    "backend:dev": "nodemon backend/server.js",

    "dev:full": "concurrently \"npm run backend\" \"npm run dev\"",

    "lint": "eslint \"src/**/*.js\" \"scripts/**/*.mjs\"",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"*.{js,ts,json}\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\" \"*.{js,ts,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
  "catalog:export": "node scripts/export-insulation-catalog.mjs",
  "frontend:dev": "vite",
  "frontend:build": "vite build",
  "backend:dev": "nodemon backend/server.js",
  "backend:start": "node backend/server.js"
  },
  "dependencies": {
    "@sentry/browser": "^8.55.0",
    "chart.js": "^4.5.1",
    "lucide": "^0.469.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "4.1.12",
    "@vitest/coverage-v8": "^3.0.9",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^16.0.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.9",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.4.2",
    "vitest": "^3.0.9"
  }
}
